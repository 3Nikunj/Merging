# ==============================================================================
# AiValytics environment configuration template.
# Copy this file to .env and replace placeholders locally. Never commit .env.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Application Settings
# ------------------------------------------------------------------------------
# Use development only for local work. Production is the backend default.
APP_ENV=development
# Comma-separated exact origins. Production and staging origins must use HTTPS.
FRONTEND_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
API_PORT=8000
FRONTEND_PORT=5173

# ------------------------------------------------------------------------------
# 2. Supabase Credentials
# ------------------------------------------------------------------------------
# Frontend-safe Supabase configuration. Use a publishable/anon key only.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Backend-only Supabase configuration.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ------------------------------------------------------------------------------
# 3. Database Connection
# ------------------------------------------------------------------------------
# Backend/database utilities only. Never expose this value through VITE_* variables.
DATABASE_URL=postgresql://YOUR_DATABASE_USER:YOUR_DATABASE_PASSWORD@YOUR_DATABASE_HOST:5432/YOUR_DATABASE_NAME

# ------------------------------------------------------------------------------
# 4. Isolated Code Execution
# ------------------------------------------------------------------------------
# Internal-only executor endpoint and shared authentication token.
SANDBOX_EXECUTOR_URL=http://sandbox-executor:8080
SANDBOX_EXECUTOR_TOKEN=GENERATE_A_LONG_RANDOM_INTERNAL_TOKEN
SANDBOX_TIMEOUT_SECONDS=2

# Production must use runsc (gVisor). Set runc only for explicit local testing.
SANDBOX_RUNTIME=runsc
SANDBOX_ALLOW_NATIVE_RUNTIME=false
SANDBOX_IMAGE=aivalytics-python-sandbox:local
SANDBOX_MAX_CONCURRENT=4
