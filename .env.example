# ==============================================================================
# AiValytics Integrated Environment Configuration Template
# Copy this file to .env and replace placeholders with active credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Application Settings
# ------------------------------------------------------------------------------
# APP_ENV: Set to 'development', 'staging', or 'production' to control logic pathing
APP_ENV=development

# FRONTEND_ORIGIN: Origin header allowed by CORS middleware in the backend API
FRONTEND_ORIGIN=http://localhost:5173

# VITE_API_BASE_URL: Target URL of the backend API for the frontend client calls
VITE_API_BASE_URL=http://localhost:8000

# API_PORT: The target host port mapping for the FastAPI backend service
API_PORT=8000

# FRONTEND_PORT: The target host port mapping for the React dev frontend service
FRONTEND_PORT=5173

# ------------------------------------------------------------------------------
# 2. Supabase Credentials
# ------------------------------------------------------------------------------
# VITE_SUPABASE_URL: Supabase Project endpoint URL (Frontend accessible)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# VITE_SUPABASE_ANON_KEY: Client-safe Supabase API public anon key (Frontend accessible)
VITE_SUPABASE_ANON_KEY=your-supabase-client-anon-key

# SUPABASE_URL: Supabase Project endpoint URL (Backend accessible)
SUPABASE_URL=https://your-project-ref.supabase.co

# SUPABASE_SERVICE_ROLE_KEY: High-privilege admin bypass token (Backend only!)
# WARNING: Keep this secret secure and never expose it to client-side bundles.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------------------------
# 3. Database Connection
# ------------------------------------------------------------------------------
# DATABASE_URL: Direct connection string to the database (used for local scripts)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
